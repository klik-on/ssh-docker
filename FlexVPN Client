conf t

! --- 1. NAT EXEMPTION (Prioritas Utama agar IP Lokal tidak berubah) ---
ip access-list extended NAT-EXEMPT
 10 deny ip 192.168.70.0 0.0.0.255 172.16.2.0 0.0.0.255
 20 deny ip 192.168.70.0 0.0.0.255 172.16.3.0 0.0.0.255
 30 permit ip 192.168.70.0 0.0.0.255 any
exit

! Pasang NAT pada interface luar
no ip nat inside source list 1 interface GigabitEthernet8 overload
ip nat inside source list NAT-EXEMPT interface GigabitEthernet8 overload

! --- 2. IKEv2 PROPOSAL & POLICY (Fase 1) ---
crypto ikev2 proposal FLEX-PROP
 encryption aes-cbc-256
 integrity sha256
 group 14
exit

crypto ikev2 policy FLEX-POL
 proposal FLEX-PROP
exit

crypto ikev2 keyring FLEX-KEY
 peer KLHK-GATEWAY
  address 103.52.213.10
  pre-shared-key Pus*******
 exit
exit

! --- 3. IKEv2 PROFILE (Identitas & Autentikasi) ---
! Pastikan username lokal sudah ada jika menggunakan aaa
username nicfi privilege 15 secret nic******

crypto ikev2 profile FLEX-PROFILE
 match identity remote address 103.52.213.10 255.255.255.255
 identity local email nicfi@klhk.go.id
 authentication local pre-share
 authentication remote pre-share
 keyring local FLEX-KEY
 aaa authorization group psk list default default
 dpd 10 3 on-demand
exit

! --- 4. IPSEC TRANSFORM-SET & PROFILE (Fase 2) ---
crypto ipsec transform-set FLEX-TSET esp-aes 256 esp-sha256-hmac
 mode tunnel
exit

crypto ipsec profile FLEX-IPSEC-PROF
 set transform-set FLEX-TSET
 set ikev2-profile FLEX-PROFILE
 set pfs group14
exit

! --- 5. INTERFACE TUNNEL ---
interface Tunnel1
 description VPN-KLHK-PUSDATIN
 ! Menggunakan IP dari Vlan1 agar source ping 192.168.70.1 valid
 ip unnumbered Vlan1 
 ip mtu 1400
 ip tcp adjust-mss 1360
 tunnel source GigabitEthernet8
 tunnel destination 103.52.213.10
 tunnel mode ipsec ipv4
 tunnel protection ipsec profile FLEX-IPSEC-PROF
 no shutdown
exit

! --- 6. STATIC ROUTING ---
ip route 172.16.2.0 255.255.255.0 Tunnel1
ip route 172.16.3.0 255.255.255.0 Tunnel1

end
write memory
